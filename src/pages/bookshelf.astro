---
import Layout from '../layouts/Layout.astro';
import booksData from '../data/books.json';

const shelves = [
  { key: 'On My Nightstand', icon: '🌙', nightstand: true },
  { key: 'Food & Kitchen',   icon: '🍽️', nightstand: false },
  { key: 'Product & Strategy', icon: '📦', nightstand: false },
  { key: 'Leadership & People', icon: '👥', nightstand: false },
];

const booksByShelf = new Map(
  shelves.map(s => [s.key, booksData.filter(b => b.shelf === s.key)])
);
---

<Layout title="Bookshelf" description="What I'm reading, have finished, and won't stop recommending.">
  <div class="bs-wrap">

    <header class="bs-header">
      <h1 class="bs-display">Bookshelf</h1>
      <p class="bs-sub">Books that shaped how I think about products, food, people, and the world.</p>
    </header>

    {shelves.map(shelf => {
      const shelfBooks = booksByShelf.get(shelf.key) ?? [];
      return (
        <section class={`bs-section${shelf.nightstand ? ' is-nightstand' : ''}`}>
          <div class="bs-inner">
            <div class="bs-row-head">
              <span class="bs-lbl">{shelf.icon}&nbsp;&nbsp;{shelf.key}</span>
              <span class="bs-cnt">{shelfBooks.length}</span>
            </div>
            <div class="bs-row">
              {shelfBooks.map(book => (
                <div class="bs-book">
                  <div class={`bs-cover ${book.color}`}>
                    <span class="bs-emoji">{book.emoji}</span>
                  </div>
                  <p class="bs-title">{book.title}</p>
                  <p class="bs-author">{book.author}</p>
                </div>
              ))}
            </div>
            <div class={`bs-ledge${shelf.nightstand ? ' ledge-warm' : ''}`}></div>
          </div>
        </section>
      );
    })}

  </div>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Outfit:wght@300;400;500&display=swap');

  html:has(.bs-wrap),
  html:has(.bs-wrap) body {
    background-color: #18140f !important;
  }
</style>

<style>
  .bs-wrap {
    background-color: #18140f;
    min-height: 60vh;
    padding-bottom: 6rem;
  }

  /* ── Header ─────────────────────────────────────────── */
  .bs-header {
    padding: 4rem 2rem 3.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .bs-display {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: #ede0cc;
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .bs-sub {
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    color: #a09078;
    margin: 0;
    line-height: 1.6;
  }

  /* ── Shelf section ───────────────────────────────────── */
  .bs-section {
    margin-bottom: 3rem;
  }

  .bs-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .bs-row-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .bs-lbl {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.3rem;
    color: #e8c9a0;
  }

  .is-nightstand .bs-lbl {
    color: #e8c9a0;
  }

  .bs-cnt {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.72rem;
    color: #5a4e3e;
  }

  /* ── Book row ────────────────────────────────────────── */
  .bs-row {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: thin;
    scrollbar-color: #5a3e28 transparent;
  }

  .bs-row::-webkit-scrollbar { height: 4px; }
  .bs-row::-webkit-scrollbar-track { background: transparent; }
  .bs-row::-webkit-scrollbar-thumb { background: #5a3e28; border-radius: 2px; }

  /* ── Book card ───────────────────────────────────────── */
  .bs-book {
    flex-shrink: 0;
    width: 112px;
  }

  .bs-cover {
    width: 112px;
    aspect-ratio: 2 / 3;
    border-radius: 3px 6px 6px 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: 3px 6px 18px rgba(0, 0, 0, 0.6), inset -3px 0 8px rgba(0, 0, 0, 0.25);
  }

  .bs-cover::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 7px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 3px 0 0 3px;
  }

  .bs-emoji {
    font-size: 2rem;
    line-height: 1;
    position: relative;
    z-index: 1;
  }

  .bs-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    color: #ede0cc;
    margin: 0.6rem 0 0.2rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bs-author {
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 0.62rem;
    color: #a09078;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Wooden ledge ────────────────────────────────────── */
  .bs-ledge {
    height: 12px;
    border-radius: 3px;
    background: linear-gradient(to bottom, #6a4830 0%, #5a3e28 40%, #3a2818 100%);
    box-shadow: 0 5px 18px rgba(0, 0, 0, 0.5);
    margin-top: 0.5rem;
  }

  .bs-ledge.ledge-warm {
    background: linear-gradient(to bottom, #7a5a38 0%, #6a4e30 40%, #4a3020 100%);
  }

  /* ── Cover color gradients (c1–c12) ─────────────────── */
  .c1  { background: linear-gradient(160deg, #1e3d30, #3a6b4a); }
  .c2  { background: linear-gradient(160deg, #7a2e1e, #b86840); }
  .c3  { background: linear-gradient(160deg, #152438, #254d7a); }
  .c4  { background: linear-gradient(160deg, #3a2c1e, #6a4c30); }
  .c5  { background: linear-gradient(160deg, #30203c, #624478); }
  .c6  { background: linear-gradient(160deg, #1e3020, #3e6848); }
  .c7  { background: linear-gradient(160deg, #3c1818, #7a3030); }
  .c8  { background: linear-gradient(160deg, #182e3c, #2e6080); }
  .c9  { background: linear-gradient(160deg, #3a2e14, #786030); }
  .c10 { background: linear-gradient(160deg, #1e3c2c, #3e6858); }
  .c11 { background: linear-gradient(160deg, #2c1e3c, #544070); }
  .c12 { background: linear-gradient(160deg, #3c2014, #785030); }
</style>
