---
import Layout from '../layouts/Layout.astro';
import books from '../data/books.json';

const allTags = [...new Set(books.flatMap(b => b.tags))].sort();
const allStatuses = [...new Set(books.map(b => b.status))];

const statusOrder = ['Currently Reading', 'Finished'];
const sortedStatuses = allStatuses.sort((a, b) => statusOrder.indexOf(a) - statusOrder.indexOf(b));

const statusStyle: Record<string, { bg: string; color: string }> = {
  'Currently Reading': { bg: 'rgba(201, 125, 78, 0.12)', color: 'var(--color-terracotta)' },
  'Finished': { bg: 'rgba(74, 124, 89, 0.1)', color: 'var(--color-forest)' },
  'Recommended': { bg: 'rgba(107, 90, 74, 0.1)', color: 'var(--color-warm-muted)' },
};
---

<Layout title="Bookshelf" description="What Jonathan Horbund is reading, has finished, and won't stop recommending.">
  <section style="padding: 4rem 1.5rem 5rem;">
    <div class="page-width" style="max-width: 860px; margin: 0 auto;">
      <h1 class="fade-in fade-in-1" style="font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 1rem;">Bookshelf</h1>
      <p class="fade-in fade-in-2" style="color: var(--color-warm-muted); font-size: 1.05rem; margin: 0 0 2.5rem; line-height: 1.7; max-width: 540px;">
        Books that have shaped how I think about products, food, people, and the world. Each note is what I'd say if you asked me to sell you on it.
      </p>

      <!-- Filters -->
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; align-items: center;">
        <span style="font-size: 0.8rem; color: var(--color-warm-muted); font-weight: 500; margin-right: 0.25rem;">Filter:</span>
        <button data-filter="all" class="shelf-btn active" style="font-size: 0.78rem; font-weight: 500; padding: 0.35rem 0.85rem; border-radius: 20px; border: 1.5px solid var(--color-terracotta); background: var(--color-terracotta); color: white; cursor: pointer; transition: all 0.2s;">All</button>
        {sortedStatuses.map(status => (
          <button data-filter={status} class="shelf-btn" style="font-size: 0.78rem; font-weight: 500; padding: 0.35rem 0.85rem; border-radius: 20px; border: 1.5px solid var(--color-sand); background: transparent; color: var(--color-warm-muted); cursor: pointer; transition: all 0.2s;">{status}</button>
        ))}
        <span style="width: 1px; height: 18px; background: var(--color-sand); margin: 0 0.25rem;"></span>
        {allTags.map(tag => (
          <button data-filter={tag} class="shelf-btn" style="font-size: 0.78rem; font-weight: 500; padding: 0.35rem 0.85rem; border-radius: 20px; border: 1.5px solid var(--color-sand); background: transparent; color: var(--color-warm-muted); cursor: pointer; transition: all 0.2s;">{tag}</button>
        ))}
      </div>

      <!-- Book list -->
      <div style="display: flex; flex-direction: column; gap: 1px;" id="books-list">
        {books.map(book => (
          <div
            class="book-item"
            data-tags={book.tags.join(',')}
            data-status={book.status}
            style="background-color: white; border-radius: 8px; padding: 1.5rem 1.75rem; margin-bottom: 0.75rem; border: 1px solid var(--color-sand); transition: box-shadow 0.2s;"
          >
            <div style="display: flex; align-items: flex-start; gap: 1.25rem; flex-wrap: wrap;">
              <!-- Spine placeholder -->
              <div style="width: 40px; flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 3px; padding-top: 2px;">
                <div style="width: 36px; height: 52px; background: linear-gradient(135deg, var(--color-sand) 0%, var(--color-terracotta) 100%); border-radius: 3px; opacity: 0.6;"></div>
              </div>
              <!-- Book details -->
              <div style="flex: 1; min-width: 200px;">
                <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
                  <div>
                    <h2 style="font-size: 1.05rem; margin: 0 0 0.2rem; line-height: 1.3;">{book.title}</h2>
                    <p style="font-size: 0.85rem; color: var(--color-warm-muted); margin: 0;">{book.author} · {book.yearRead}</p>
                  </div>
                  <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; flex-shrink: 0;">
                    <span style={`font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 20px; background-color: ${(statusStyle[book.status] ?? statusStyle['Finished']).bg}; color: ${(statusStyle[book.status] ?? statusStyle['Finished']).color};`}>
                      {book.status}
                    </span>
                    <div style="display: flex; gap: 0.3rem; flex-wrap: wrap; justify-content: flex-end;">
                      {book.tags.map(tag => (
                        <span style="font-size: 0.68rem; color: var(--color-warm-muted); background-color: var(--color-cream); border: 1px solid var(--color-sand); padding: 0.1rem 0.4rem; border-radius: 20px;">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
                <p style="font-size: 0.9rem; color: var(--color-charcoal); margin: 0.75rem 0 0; line-height: 1.65; font-style: italic;">"{book.note}"</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.shelf-btn');
  const items = document.querySelectorAll<HTMLElement>('.book-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      buttons.forEach(b => {
        const active = b === btn;
        b.classList.toggle('active', active);
        b.style.backgroundColor = active ? 'var(--color-terracotta)' : 'transparent';
        b.style.borderColor = active ? 'var(--color-terracotta)' : 'var(--color-sand)';
        b.style.color = active ? 'white' : 'var(--color-warm-muted)';
      });

      items.forEach(item => {
        if (filter === 'all') {
          item.style.display = 'block';
          return;
        }
        const tags = item.dataset.tags?.split(',') ?? [];
        const status = item.dataset.status ?? '';
        item.style.display = (tags.includes(filter) || status === filter) ? 'block' : 'none';
      });
    });
  });
</script>
