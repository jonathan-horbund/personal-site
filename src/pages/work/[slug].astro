---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allWork = await getCollection('work');
const sorted = allWork.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIdx = sorted.findIndex(w => w.id === entry.id);
const prev = currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
const next = currentIdx > 0 ? sorted[currentIdx - 1] : null;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
}
---

<Layout title={entry.data.title} description={entry.data.description}>
  <article>
    <!-- Header -->
    <header style="background-color: white; border-bottom: 1px solid var(--color-sand); padding: 3rem 1.5rem 2.5rem;">
      <div class="content-width">
        <a href="/work" style="font-size: 0.85rem; color: var(--color-warm-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1.5rem; transition: color 0.2s;" class="back-link">
          ← Back to Work
        </a>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem;">
          {entry.data.tags.map(tag => (
            <span style="font-size: 0.75rem; font-weight: 600; background-color: var(--color-sand); color: var(--color-warm-muted); padding: 0.25rem 0.75rem; border-radius: 20px;">
              {tag}
            </span>
          ))}
        </div>
        <h1 style="font-size: clamp(1.75rem, 4vw, 2.75rem); margin: 0 0 1rem; line-height: 1.15;">{entry.data.title}</h1>
        {(entry.data.role || entry.data.timeline) && (
          <p style="font-size: 0.875rem; color: var(--color-warm-muted); margin: 0;">
            {entry.data.role}{entry.data.timeline ? ` · ${entry.data.timeline}` : ''} · {formatDate(entry.data.date)}
          </p>
        )}
      </div>
    </header>

    <!-- TL;DR -->
    {entry.data.tldr && (
      <div style="padding: 2rem 1.5rem; background-color: rgba(201, 125, 78, 0.07); border-bottom: 1px solid rgba(201, 125, 78, 0.15);">
        <div class="content-width">
          <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-terracotta); margin: 0 0 0.5rem;">TL;DR</p>
          <p style="font-size: 1rem; color: var(--color-charcoal); margin: 0; line-height: 1.7; font-style: italic;">{entry.data.tldr}</p>
        </div>
      </div>
    )}

    <!-- Body -->
    <div style="padding: 3rem 1.5rem 4rem;">
      <div class="content-width prose">
        <Content />
      </div>
    </div>

    <!-- Prev / Next -->
    <nav style="border-top: 1px solid var(--color-sand); padding: 2rem 1.5rem;" aria-label="Case study navigation">
      <div class="page-width" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          {prev && (
            <a href={`/work/${prev.id}`} style="display: block; text-decoration: none; padding: 1rem; border-radius: 8px; border: 1px solid var(--color-sand); transition: border-color 0.2s;" class="nav-card">
              <p style="font-size: 0.75rem; color: var(--color-warm-muted); margin: 0 0 0.25rem;">← Previous</p>
              <p style="font-size: 0.9rem; font-weight: 600; color: var(--color-charcoal); margin: 0; line-height: 1.3;">{prev.data.title}</p>
            </a>
          )}
        </div>
        <div style="text-align: right;">
          {next && (
            <a href={`/work/${next.id}`} style="display: block; text-decoration: none; padding: 1rem; border-radius: 8px; border: 1px solid var(--color-sand); transition: border-color 0.2s;" class="nav-card">
              <p style="font-size: 0.75rem; color: var(--color-warm-muted); margin: 0 0 0.25rem;">Next →</p>
              <p style="font-size: 0.9rem; font-weight: 600; color: var(--color-charcoal); margin: 0; line-height: 1.3;">{next.data.title}</p>
            </a>
          )}
        </div>
      </div>
    </nav>
  </article>
</Layout>

<style>
  .back-link:hover { color: var(--color-terracotta) !important; }
  .nav-card:hover { border-color: var(--color-terracotta) !important; }

  .prose :global(h2) {
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
    color: var(--color-charcoal);
  }
  .prose :global(h3) {
    font-size: 1.15rem;
    margin: 2rem 0 0.75rem;
    color: var(--color-charcoal);
  }
  .prose :global(p) {
    color: var(--color-charcoal);
    line-height: 1.75;
    margin: 0 0 1.25rem;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .prose :global(li) {
    line-height: 1.7;
    margin-bottom: 0.5rem;
    color: var(--color-charcoal);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-terracotta);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-warm-muted);
  }
  .prose :global(strong) {
    color: var(--color-charcoal);
    font-weight: 600;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-sand);
    margin: 2.5rem 0;
  }
</style>
