---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const sorted = allWork.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(sorted.flatMap(w => w.data.tags))].sort();
---

<Layout title="Work" description="PM case studies from Capital One and beyond — strategy, discovery, and delivery work.">
  <section style="padding: 4rem 1.5rem 5rem;">
    <div class="page-width">
      <!-- Header -->
      <div style="max-width: 600px; margin-bottom: 3rem;">
        <h1 class="fade-in fade-in-1" style="font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 1rem;">Work</h1>
        <p class="fade-in fade-in-2" style="color: var(--color-warm-muted); font-size: 1.05rem; line-height: 1.7; margin: 0;">
          I believe great product work starts with understanding people, not requirements. Here are some cases that shaped how I think.
        </p>
      </div>

      <!-- Tag filter -->
      <div id="tag-filter" style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem;">
        <button
          data-tag="all"
          class="tag-btn active"
          style="font-size: 0.8rem; font-weight: 500; padding: 0.4rem 1rem; border-radius: 20px; border: 1.5px solid var(--color-terracotta); background-color: var(--color-terracotta); color: white; cursor: pointer; transition: all 0.2s;"
        >
          All
        </button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag-btn"
            style="font-size: 0.8rem; font-weight: 500; padding: 0.4rem 1rem; border-radius: 20px; border: 1.5px solid var(--color-sand); background-color: transparent; color: var(--color-warm-muted); cursor: pointer; transition: all 0.2s;"
          >
            {tag}
          </button>
        ))}
      </div>

      <!-- Case study cards -->
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;" id="work-grid">
        {sorted.map(item => (
          <article
            class="card-hover work-card"
            data-tags={item.data.tags.join(',')}
            style="background-color: white; border: 1px solid var(--color-sand); border-radius: 10px; padding: 2rem; display: flex; flex-direction: column;"
          >
            <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem;">
              {item.data.tags.map(tag => (
                <span style="font-size: 0.72rem; font-weight: 600; background-color: var(--color-sand); color: var(--color-warm-muted); padding: 0.25rem 0.625rem; border-radius: 20px; letter-spacing: 0.02em;">
                  {tag}
                </span>
              ))}
            </div>
            <h2 style="font-size: 1.2rem; margin: 0 0 0.625rem; line-height: 1.3;">{item.data.title}</h2>
            {item.data.role && (
              <p style="font-size: 0.8rem; color: var(--color-terracotta); font-weight: 500; margin: 0 0 0.75rem;">{item.data.role} {item.data.timeline ? `· ${item.data.timeline}` : ''}</p>
            )}
            <p style="color: var(--color-warm-muted); font-size: 0.9rem; margin: 0 0 1.5rem; flex: 1; line-height: 1.6;">{item.data.description}</p>
            <a href={`/work/${item.id}`} style="font-size: 0.875rem; font-weight: 600; color: var(--color-terracotta); text-decoration: none;">
              Read case study →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards = document.querySelectorAll<HTMLElement>('.work-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all';

      buttons.forEach(b => {
        const isActive = b === btn;
        b.classList.toggle('active', isActive);
        b.style.backgroundColor = isActive ? 'var(--color-terracotta)' : 'transparent';
        b.style.borderColor = isActive ? 'var(--color-terracotta)' : 'var(--color-sand)';
        b.style.color = isActive ? 'white' : 'var(--color-warm-muted)';
      });

      cards.forEach(card => {
        const tags = card.dataset.tags?.split(',') ?? [];
        const show = tag === 'all' || tags.includes(tag);
        card.style.display = show ? 'flex' : 'none';
      });
    });
  });
</script>
