---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('recipes');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allRecipes = await getCollection('recipes');
const sorted = allRecipes.sort((a, b) => a.data.title.localeCompare(b.data.title));
const currentIdx = sorted.findIndex(r => r.id === entry.id);
const prev = currentIdx > 0 ? sorted[currentIdx - 1] : null;
const next = currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
---

<Layout title={entry.data.title} description={`${entry.data.category} · ${entry.data.difficulty} · Serves ${entry.data.serves}`}>
  <article>
    <!-- Header -->
    <header style="background-color: white; border-bottom: 1px solid var(--color-sand); padding: 3rem 1.5rem 2.5rem;">
      <div class="content-width">
        <a href="/recipes" style="font-size: 0.85rem; color: var(--color-warm-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1.5rem; transition: color 0.2s;" class="back-link">
          ← All recipes
        </a>
        <span style="display: inline-block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-terracotta); margin-bottom: 0.75rem;">
          {entry.data.category}{entry.data.cuisine ? ` · ${entry.data.cuisine}` : ''}
        </span>
        <h1 style="font-size: clamp(1.75rem, 4vw, 2.75rem); margin: 0 0 1.5rem; line-height: 1.15;">{entry.data.title}</h1>

        <!-- Meta strip -->
        <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; padding: 1.25rem 1.5rem; background-color: var(--color-cream); border-radius: 8px; border: 1px solid var(--color-sand);">
          <div style="text-align: center;">
            <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-warm-muted); margin: 0 0 0.25rem;">Prep</p>
            <p style="font-size: 1rem; font-weight: 600; margin: 0; color: var(--color-charcoal);">{entry.data.prepTime}</p>
          </div>
          <div style="text-align: center;">
            <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-warm-muted); margin: 0 0 0.25rem;">Cook</p>
            <p style="font-size: 1rem; font-weight: 600; margin: 0; color: var(--color-charcoal);">{entry.data.cookTime}</p>
          </div>
          <div style="text-align: center;">
            <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-warm-muted); margin: 0 0 0.25rem;">Serves</p>
            <p style="font-size: 1rem; font-weight: 600; margin: 0; color: var(--color-charcoal);">{entry.data.serves}</p>
          </div>
          <div style="text-align: center;">
            <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-warm-muted); margin: 0 0 0.25rem;">Difficulty</p>
            <p style="font-size: 1rem; font-weight: 600; margin: 0; color: var(--color-charcoal);">{entry.data.difficulty}</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Story behind the dish -->
    {entry.data.story && (
      <div style="padding: 2rem 1.5rem; background-color: rgba(74, 124, 89, 0.06); border-bottom: 1px solid rgba(74, 124, 89, 0.12);">
        <div class="content-width">
          <p style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-forest); margin: 0 0 0.5rem;">The story</p>
          <p style="font-size: 1rem; color: var(--color-charcoal); margin: 0; line-height: 1.75; font-style: italic;">{entry.data.story}</p>
        </div>
      </div>
    )}

    <!-- Body content -->
    <div style="padding: 3rem 1.5rem 4rem;">
      <div class="content-width recipe-prose">
        <Content />
      </div>
    </div>

    <!-- Prev / Next -->
    <nav style="border-top: 1px solid var(--color-sand); padding: 2rem 1.5rem;" aria-label="Recipe navigation">
      <div class="page-width" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          {prev && (
            <a href={`/recipes/${prev.id}`} style="display: block; text-decoration: none; padding: 1rem; border-radius: 8px; border: 1px solid var(--color-sand); transition: border-color 0.2s;" class="nav-card">
              <p style="font-size: 0.75rem; color: var(--color-warm-muted); margin: 0 0 0.25rem;">← Previous</p>
              <p style="font-size: 0.875rem; font-weight: 600; color: var(--color-charcoal); margin: 0;">{prev.data.title}</p>
            </a>
          )}
        </div>
        <div style="text-align: right;">
          {next && (
            <a href={`/recipes/${next.id}`} style="display: block; text-decoration: none; padding: 1rem; border-radius: 8px; border: 1px solid var(--color-sand); transition: border-color 0.2s;" class="nav-card">
              <p style="font-size: 0.75rem; color: var(--color-warm-muted); margin: 0 0 0.25rem;">Next →</p>
              <p style="font-size: 0.875rem; font-weight: 600; color: var(--color-charcoal); margin: 0;">{next.data.title}</p>
            </a>
          )}
        </div>
      </div>
    </nav>
  </article>
</Layout>

<style>
  .back-link:hover { color: var(--color-terracotta) !important; }
  .nav-card:hover { border-color: var(--color-terracotta) !important; }

  .recipe-prose :global(h2) {
    font-size: 1.4rem;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-sand);
  }
  .recipe-prose :global(h3) {
    font-size: 1rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-terracotta);
  }
  .recipe-prose :global(p) { color: var(--color-charcoal); line-height: 1.75; margin: 0 0 1rem; }
  .recipe-prose :global(ul), .recipe-prose :global(ol) { padding-left: 1.5rem; margin: 0 0 1.25rem; }
  .recipe-prose :global(li) { line-height: 1.7; margin-bottom: 0.4rem; color: var(--color-charcoal); }
  .recipe-prose :global(strong) { font-weight: 600; color: var(--color-charcoal); }

  @media print {
    header a, nav { display: none; }
    header { border: none; }
  }
</style>
