---
import Layout from '../layouts/Layout.astro';
import volunteering from '../data/volunteering.json';
---

<Layout title="Volunteering" description="Jonathan Horbund's kitchen volunteer work and the causes he shows up for.">
  <section style="padding: 4rem 1.5rem 5rem;">
    <div class="page-width" style="max-width: 800px; margin: 0 auto;">
      <!-- Header -->
      <h1 class="fade-in fade-in-1" style="font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 1rem;">Volunteering</h1>

      <!-- Personal statement -->
      <div class="fade-in fade-in-2" style="max-width: 600px; margin-bottom: 3.5rem;">
        <p style="font-size: 1.1rem; color: var(--color-charcoal); line-height: 1.8; margin: 0 0 1.25rem;">
          José Andrés has a line I keep coming back to: <em style="color: var(--color-terracotta);">"Food can change the world."</em> He means it literally. So do I.
        </p>
        <p style="font-size: 1rem; color: var(--color-warm-muted); line-height: 1.8; margin: 0 0 1.25rem;">
          I started volunteering in professional kitchens a few years ago, and it became one of the most clarifying things I've ever done. There's something about the discipline of a kitchen service — the mise en place, the teamwork, the fact that someone is hungry and counting on you — that cuts through a lot of noise.
        </p>
        <p style="font-size: 1rem; color: var(--color-warm-muted); line-height: 1.8; margin: 0;">
          These are the organizations and programs I show up for. All of them believe, in different ways, that access to good food is not a luxury. Neither do I.
        </p>
      </div>

      <!-- Organization cards -->
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        {volunteering.map((org, i) => (
          <div
            class="fade-in"
            style={`animation-delay: ${0.1 + i * 0.1}s; background-color: white; border: 1px solid var(--color-sand); border-radius: 10px; padding: 2rem; display: flex; gap: 1.5rem; align-items: flex-start; flex-wrap: wrap;`}
          >
            <!-- Icon -->
            <div style="width: 52px; height: 52px; border-radius: 10px; background-color: var(--color-cream); border: 1px solid var(--color-sand); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-terracotta)" stroke-width="1.5" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                <path d="M8 12h8M12 8v8"/>
              </svg>
            </div>
            <!-- Details -->
            <div style="flex: 1; min-width: 200px;">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
                <div>
                  <h2 style="font-size: 1.1rem; margin: 0 0 0.2rem; line-height: 1.3;">{org.organization}</h2>
                  <p style="font-size: 0.85rem; color: var(--color-terracotta); font-weight: 500; margin: 0;">{org.role}</p>
                </div>
                <div style="text-align: right; flex-shrink: 0;">
                  <p style="font-size: 0.8rem; color: var(--color-warm-muted); margin: 0;">{org.timeframe}</p>
                  <p style="font-size: 0.78rem; color: var(--color-warm-muted); margin: 0.15rem 0 0;">{org.location}</p>
                </div>
              </div>
              <p style="font-size: 0.9rem; color: var(--color-warm-muted); margin: 0.75rem 0 0; line-height: 1.7;">{org.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Closing note -->
      <div style="margin-top: 3rem; padding: 2rem; background-color: rgba(201, 125, 78, 0.07); border-radius: 10px; border: 1px solid rgba(201, 125, 78, 0.2);">
        <p style="font-size: 1rem; color: var(--color-charcoal); margin: 0; line-height: 1.75; font-style: italic; text-align: center;">
          "The world eats better when there are more cooks."<br/>
          <span style="font-style: normal; font-size: 0.85rem; color: var(--color-warm-muted);">— José Andrés</span>
        </p>
      </div>
    </div>
  </section>
</Layout>
