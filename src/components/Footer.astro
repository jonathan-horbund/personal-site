---
const navLinks = [
  { href: '/work', label: 'Work' },
  { href: '/writing', label: 'Writing' },
  { href: '/recipes', label: 'Recipes' },
  { href: '/bookshelf', label: 'Bookshelf' },
  { href: '/volunteering', label: 'Volunteering' },
  { href: '/about', label: 'About' },
];
---

<footer style="background-color: var(--color-charcoal); color: var(--color-cream); margin-top: auto;">
  <div class="page-width" style="padding: 3rem 1.5rem 2rem;">
    <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
      <!-- Brand -->
      <div>
        <p style="font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 600; margin: 0 0 0.5rem;">
          Jonathan Horbund
        </p>
        <p style="font-size: 0.9rem; color: var(--color-sand); margin: 0; font-style: italic;">
          "Building bigger tables."
        </p>
      </div>

      <!-- Nav -->
      <nav aria-label="Footer navigation">
        <ul style="display: flex; flex-wrap: wrap; gap: 1rem 2rem; list-style: none; margin: 0; padding: 0;">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                style="font-size: 0.875rem; color: var(--color-sand); text-decoration: none; transition: color 0.2s;"
                class="footer-link"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- LinkedIn + copyright -->
      <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; padding-top: 1.5rem; border-top: 1px solid rgba(232, 201, 160, 0.2);">
        <a
          href="https://www.linkedin.com/in/jonathanhorbund"
          target="_blank"
          rel="noopener noreferrer"
          style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--color-sand); text-decoration: none; transition: color 0.2s;"
          class="footer-link"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <p style="font-size: 0.8rem; color: var(--color-warm-muted); margin: 0;">
          © {new Date().getFullYear()} Jonathan Horbund
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--color-terracotta) !important;
  }
</style>
